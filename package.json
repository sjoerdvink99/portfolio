{
  "name": "my-project",
  "version": "0.1.0",
  "homepage": "https://sjoerdvink99.github.io/portfolio/",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "scripts": {
    "start": "bun run build && bun dev.js",
    "build": "bun build-simple.js && bun build src/index.tsx --outdir build --target browser --minify",
    "build:deploy": "bun build-simple.js --deploy && bun build src/index.tsx --outdir build --target browser --minify",
    "deploy": "bun run build:deploy && gh-pages -d build",
    "typecheck": "tsc --noEmit"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.0.5",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "gh-pages": "^6.0.0",
    "tailwindcss": "^3.3.3",
    "typescript": "^5.9.3"
  }
}
